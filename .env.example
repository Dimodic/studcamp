# Postgres (используется сервисом db в docker-compose)
POSTGRES_DB=studcamp
POSTGRES_USER=studcamp
POSTGRES_PASSWORD=studcamp

# Backend
STUDCAMP_ENV=production
STUDCAMP_DATABASE_URL=postgresql+psycopg://studcamp:studcamp@db:5432/studcamp
# CORS-origin(s) под фактический адрес приложения. В compose по умолчанию
# фронт раздаётся на :8080 через nginx, и запросы к /api идут same-origin —
# поэтому CORS реально не нужен, но backend требует непустое значение.
STUDCAMP_CORS_ORIGINS=http://localhost:8080

# Порт, на котором будет доступен веб-интерфейс (nginx-контейнер).
WEB_PORT=8080

# Telegram WebApp-авторизация. Если оба значения пустые/нулевые —
# endpoint /auth/telegram вернёт 503, и приложение работает только через
# email/password (dev-режим).
# Токен — у @BotFather после /newbot. chat_id целевой группы — отрицательный
# (супергруппы: -100xxxxxxxxxx); быстрый способ узнать — отправить в группе
# сообщение от бота и сделать getUpdates.
STUDCAMP_TELEGRAM_BOT_TOKEN=
STUDCAMP_TELEGRAM_GROUP_ID=

# Публичный демо-вход. Если указать id существующего пользователя-организатора,
# любой, кто откроет сайт в браузере (без Telegram и без сохранённой сессии),
# сразу попадает в интерфейс этого организатора без ввода пароля. Нужно для
# презентационной прямой ссылки. Пусто — фича выключена, /auth/demo → 404.
# ВНИМАНИЕ: все действия демо-сеанса реально меняют БД и видны всем, кто
# откроет сайт. Используйте отдельного демо-пользователя, а не боевого.
STUDCAMP_DEMO_ORGANIZER_ID=

# Для локальной разработки без docker (npm run dev + uvicorn):
# VITE_API_BASE_URL=http://localhost:8000/api/v1
